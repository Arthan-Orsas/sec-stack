# ============================================================
# .env.example
# Copier ce fichier en ".env" puis renseigner les valeurs réelles.
# ============================================================

# --- Mailjet (SMTP Grafana) ---
MAILJET_API_KEY=change-me
MAILJET_SECRET_KEY=change-me

# --- Microsoft Entra ID / Azure AD (entra-collector) ---
TENANT_ID=00000000-0000-0000-0000-000000000000
CLIENT_ID=00000000-0000-0000-0000-000000000000
CLIENT_SECRET=change-me
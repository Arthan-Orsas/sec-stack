          "editorMode": "code",
          "expr": "topk(10,\r\n  sum by (app) (\r\n    count_over_time(\r\n      {source=\"entra_id\", filename=~\"/logs/entra_signins_.*\\\\.jsonl\"}\r\n      | json errorCode=\"event.status.errorCode\", app=\"event.appDisplayName\"\r\n      | errorCode != \"0\"\r\n      | app != \"\"\r\n      [24h]\r\n    )\r\n  )\r\n)",
          "legendFormat": "{{app}}",
          "queryType": "instant",
          "refId": "A"
        }
      ],
